# ============================================
# Tabletop - Environment Configuration
# Copy this file to .env and fill in real values
# ============================================

# Server
PORT=8080
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000

# Database (NeonDB for production, local Postgres for dev)
# Format: postgres://user:password@host:port/database?sslmode=require
DATABASE_URL=postgres://dev:dev@localhost:5432/tabletop?sslmode=disable

# Redis (Upstash for production, local Redis for dev)
REDIS_URL=redis://localhost:6379

# ============================================
# Clerk Authentication
# Get these from https://dashboard.clerk.com/
# ============================================
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# ============================================
# External APIs
# ============================================

# TMDB API Key - get from https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# OpenAI API Key - get from https://platform.openai.com/api-keys
# This is used server-side to proxy AI requests with rate limiting
OPENAI_API_KEY=sk-...
