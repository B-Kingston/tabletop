# ============================================
# Tabletop Mobile — Environment Configuration
# ============================================
#
# Copy this file to .env in the mobile directory:
#
#     cp mobile/.env.example mobile/.env
#
# mobile/.env is gitignored and will NEVER be committed.
#
# ════════════════════════════════════════════
#
# 🔑 EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY
#    Your Clerk publishable key from Clerk Dashboard → API Keys.
#    Looks like: pk_test_fJ2b8xK...
#    → Uses test mode (pk_test_*) for dev, live (pk_live_*) for production.
#    → This key is safe to expose in client-side code.
#
# 🌐 EXPO_PUBLIC_API_URL
#    The base URL of the Tabletop backend API.
#    Must include the /v1 prefix.
#    The correct value depends on WHERE you're running the mobile app:
#
#    ─── iOS Simulator ───
#    The simulator runs on your Mac and shares its network stack.
#    "localhost" in the simulator IS your Mac.
#
#        EXPO_PUBLIC_API_URL=http://localhost:8080/v1
#
#    ─── Android Emulator ───
#    The emulator uses a virtual router.  The host machine is always
#    reachable at 10.0.2.2 (Android's built-in alias for the host loopback).
#
#        EXPO_PUBLIC_API_URL=http://10.0.2.2:8080/v1
#
#    ─── Physical Device ───
#    Your phone is on the same Wi-Fi as your Mac.  Use your Mac's
#    local network IP address (NOT 127.0.0.1 — that's the phone itself).
#    Find your IP:  System Settings → Wi-Fi → Details → IP Address
#    Or run:        ifconfig en0 | grep 'inet ' | awk '{print $2}'
#
#        EXPO_PUBLIC_API_URL=http://192.168.1.123:8080/v1
#                                         ^^^^^^^^^^^^
#                                         Your Mac's IP
#
#    ⚠️  If the backend is behind a VPN or firewall, physical device
#    access may not work.  In that case, use the iOS Simulator or
#    Android Emulator instead.
#
# ════════════════════════════════════════════

EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# ─── iOS Simulator (default) ───
EXPO_PUBLIC_API_URL=http://localhost:8080/v1

# ─── Android Emulator ───
# EXPO_PUBLIC_API_URL=http://10.0.2.2:8080/v1

# ─── Physical device ───
# EXPO_PUBLIC_API_URL=http://192.168.1.123:8080/v1
