# ============================================
# Tabletop - Dev Environment (no real keys needed)
# Copy to .env.dev and run: ./dev-run.sh
# ============================================

ENVIRONMENT=development
DEV_SKIP_AUTH=true

PORT=8080
FRONTEND_URL=http://localhost:3000

# Local infrastructure (started via docker compose)
DATABASE_URL=postgres://dev:dev@localhost:5432/tabletop?sslmode=disable
REDIS_URL=redis://localhost:6379

# Clerk — ignored when DEV_SKIP_AUTH=true
CLERK_SECRET_KEY=sk_test_dev
CLERK_JWKS_URL=https://clerk.local/.well-known/jwks.json
CLERK_PUBLISHABLE_KEY=pk_test_dev
CLERK_WEBHOOK_SECRET=whsec_dev

# External APIs — ignored when DEV_SKIP_AUTH=true
TMDB_API_KEY=dev
OPENAI_API_KEY=
