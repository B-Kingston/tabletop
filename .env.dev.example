# ============================================
# Tabletop — Dev Environment Configuration
# ============================================
#
# This file is a TEMPLATE. Copy it to create your local config:
#
#     cp .env.dev.example .env.dev
#
# .env.dev is gitignored and will NEVER be committed.
#
# ════════════════════════════════════════════
#
# There are TWO modes for local development:
#
# ┌────────────────────────────────────────────────┐
# │  MODE 1: Mock Auth  (default, zero setup)     │
# └────────────────────────────────────────────────┘
#   DEV_SKIP_AUTH=true
#
#   → Clerk authentication is COMPLETELY bypassed.
#   → No JWT signature verification.
#   → You're signed in automatically as "Dev User".
#   → TMDB / OpenAI API calls are skipped or mocked.
#   → ALL the dummy keys below work fine — edit nothing.
#
#   Best for: UI development, CSS, layout, backend
#   API work with curl/Postman, quick smoke tests.
#
#   Start:    ./dev.sh
#
# ┌────────────────────────────────────────────────┐
# │  MODE 2: Real Auth  (full-stack integration)  │
# └────────────────────────────────────────────────┘
#   DEV_SKIP_AUTH=false
#
#   → Clerk JWTs are verified against Clerk's
#     JWKS endpoint using real cryptographic keys.
#   → You MUST sign in with a real Clerk account.
#   → TMDB proxy calls the real TMDB API.
#   → OpenAI proxy calls the real OpenAI API.
#   → EVERY key in [REAL KEYS MODE] is REQUIRED.
#
#   Best for: auth flow testing, TMDB search,
#   AI features, pre-production validation.
#
#   Start:    ./dev.sh --with-auth
#             (validates all keys before starting)
#
# ════════════════════════════════════════════

ENVIRONMENT=development
DEV_SKIP_AUTH=true

PORT=8080
FRONTEND_URL=http://localhost:3000

# ─── Local infrastructure (started by docker compose) ───
DATABASE_URL=postgres://dev:dev@localhost:5432/tabletop?sslmode=disable
REDIS_URL=redis://localhost:6379

# ─── Clerk — IGNORED when DEV_SKIP_AUTH=true ───
# These dummy values are fine for Mode 1. They are never validated.
CLERK_SECRET_KEY=sk_test_dev
CLERK_JWKS_URL=https://clerk.local/.well-known/jwks.json
CLERK_PUBLISHABLE_KEY=pk_test_dev
CLERK_WEBHOOK_SECRET=whsec_dev
CLERK_ISSUER=
CLERK_AUDIENCE=

# ─── External APIs — IGNORED when DEV_SKIP_AUTH=true ───
TMDB_API_KEY=dev
OPENAI_API_KEY=

# ════════════════════════════════════════════
# [REAL KEYS MODE] — Template
# ════════════════════════════════════════════
#
# When you need REAL auth (./dev.sh --with-auth), you must replace
# the dummy values ABOVE with real keys.  Follow the steps below.
#
# ─── WHERE TO GET EACH KEY ───
#
# 🔑 CLERK_SECRET_KEY
#    Clerk Dashboard → Your App → "API Keys" → "Secret Keys"
#    URL:  https://dashboard.clerk.com/apps
#    Looks like:  sk_test_fJ2b8xK...   (test mode — use for dev)
#    Looks like:  sk_live_fJ2b8xK...   (live mode — production only)
#    → Use sk_test_* for local development.
#
# 🔑 CLERK_PUBLISHABLE_KEY
#    Same page as the secret key (Clerk Dashboard → API Keys).
#    Looks like:  pk_test_fJ2b8xK...
#    → This key is safe to expose in frontend/mobile code.
#
# 🔑 CLERK_JWKS_URL
#    Clerk Dashboard → Your App → "API Keys" → "Advanced" → "JWKS URL"
#    Looks like:  https://witty-griffon-12.clerk.accounts.dev/.well-known/jwks.json
#    → Replace "witty-griffon-12" with YOUR Clerk domain.
#
# 🔑 CLERK_ISSUER
#    Your Clerk domain without the path:
#    Looks like:  https://witty-griffon-12.clerk.accounts.dev
#    → Must match the "iss" claim in Clerk-issued JWTs.
#
# 🔑 CLERK_AUDIENCE
#    Any string you choose, e.g. "tabletop".
#    → Must match the "aud" claim you configure in Clerk Dashboard.
#
# 🔑 CLERK_WEBHOOK_SECRET (optional for local dev)
#    Clerk Dashboard → Your App → "Webhooks" → "Signing Secret"
#    Looks like:  whsec_8xK9m...
#    → Only needed if you're testing Clerk webhooks locally.
#
# 🔑 TMDB_API_KEY
#    TMDB Developer Portal → Settings → API → "API Key (v3 auth)"
#    URL:  https://www.themoviedb.org/settings/api
#    → Register a free TMDB account, then request an API key.
#    Looks like:  1a2b3c4d5e...   (32 hex chars)
#
# 🔑 OPENAI_API_KEY (optional — only for AI features)
#    OpenAI Platform → API Keys → "Create new secret key"
#    URL:  https://platform.openai.com/api-keys
#    Looks like:  sk-proj-...
#    → You need a funded OpenAI account.
#
# ─── EXAMPLE REAL VALUES (do NOT copy these — they're fake) ───
# Uncomment and replace with YOUR actual keys:
#
# DEV_SKIP_AUTH=false
#
# CLERK_SECRET_KEY=sk_test_yourActualClerkSecretKeyHere
# CLERK_PUBLISHABLE_KEY=pk_test_yourActualClerkPublishableKeyHere
# CLERK_JWKS_URL=https://your-domain-12.clerk.accounts.dev/.well-known/jwks.json
# CLERK_ISSUER=https://your-domain-12.clerk.accounts.dev
# CLERK_AUDIENCE=tabletop
# CLERK_WEBHOOK_SECRET=whsec_yourActualWebhookSecretHere
# TMDB_API_KEY=your32charTmdbApiKeyHere
# OPENAI_API_KEY=sk-proj-yourOpenAIKeyHere
